{
  "compilerOptions": {
    "target": "ES2019",
    "module": "es6",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "esModuleInterop": true
  },
  "include": ["src/**/*", "dist/script.js"],
  "exclude": ["node_modules"]
}
